# Neon Postgres
# Obtain a connection string for your database from the Connection Details widget on the Neon Dashboard.
DATABASE_URL="<postgres://user:pass@host/db>"

# Neon Auth (enable in Neon Console → Auth → copy Auth URL)
# Auth URL looks like: https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_BASE_URL="https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth"
# Session cookie signing (min 32 chars): openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="<generated-secret-at-least-32-chars>"

# Anthropic (required for Creative Flow)
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
